# Code Reviewer MCP 服务器配置
# 复制此文件为 .env 并填入你的配置

# AI 模型 API 密钥（必填）
CODE_REVIEW_API_KEY=your-api-key-here

# API 端点地址（必填）
CODE_REVIEW_BASE_URL=https://api.openai.com/v1

# 使用的模型名称（可选）
# 支持 OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# 支持小米: mimo-v2.5, mimo-v2.5-pro
# 支持其他兼容 OpenAI 格式的 API
CODE_REVIEW_MODEL=gpt-4

# 调试日志（可选，1 启用）
# CODE_REVIEWER_DEBUG=1
